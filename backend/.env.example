NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/ai-platform

JWT_ACCESS_SECRET=change_me_to_a_long_access_secret
JWT_REFRESH_SECRET=change_me_to_a_long_refresh_secret
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

GOOGLE_CLIENT_ID=
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MAX_COMPLETION_TOKENS=700

RAG_SERVICE_URL=http://localhost:8001
RAG_TOP_K=3
RAG_CONTEXT_MAX_CHARS=4500
RAG_CONTEXT_CHUNK_MAX_CHARS=1500
CHAT_HISTORY_LIMIT=4

# Local development:
# REDIS_URL=redis://localhost:6379
#
# Upstash production Redis protocol endpoint:
REDIS_URL=rediss://default:YOUR_UPSTASH_PASSWORD@YOUR_UPSTASH_HOST.upstash.io:6379
REDIS_TLS_REJECT_UNAUTHORIZED=true
REDIS_CONNECT_TIMEOUT_MS=10000
REDIS_MAX_RECONNECT_DELAY_MS=10000

UPLOAD_DIR=uploads
INGESTION_WORKER_CONCURRENCY=2
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://localhost:8080,http://localhost:8081,http://127.0.0.1:8080,http://127.0.0.1:8081
COOKIE_DOMAIN=
